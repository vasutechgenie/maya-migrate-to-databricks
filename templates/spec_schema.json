{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DMA authored pipeline spec",
  "type": "object",
  "required": ["summary", "parity"],
  "properties": {
    "summary": {"type": "string"},
    "bronze": {"$ref": "#/definitions/layer"},
    "silver": {"$ref": "#/definitions/layer"},
    "gold": {"$ref": "#/definitions/layer"},
    "parity": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["table"],
        "properties": {
          "table": {"type": "string"},
          "keys": {"type": "array", "items": {"type": "string"}},
          "columns": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
    "flags": {"type": "array", "items": {"type": "string"}}
  },
  "definitions": {
    "layer": {
      "type": "object",
      "required": ["desc", "code"],
      "properties": {
        "desc": {"type": "string"},
        "code": {"type": "string"},
        "language": {"type": "string", "enum": ["sql", "pyspark"]}
      }
    }
  }
}
